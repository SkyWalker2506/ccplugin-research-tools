{
  "cds_version": "1.0",
  "name": "ccplugin-research-tools",
  "type": "plugin",
  "input_patterns": [
    {
      "type": "slash_command",
      "commands": [
        "/run-research",
        "/run-analysis",
        "/run-prd"
      ]
    },
    {
      "type": "auto_trigger",
      "keywords": [
        "research",
        "analysis",
        "prd",
        "market research",
        "rakip analizi"
      ],
      "confirm": false,
      "cooldown": 0
    }
  ],
  "output_patterns": [
    {
      "type": "terminal_text",
      "max_lines": 20
    },
    {
      "type": "file_generation",
      "path": "analysis/ markdown reports"
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [],
      "required_secrets": [],
      "required_mcp": [
        "fetch"
      ]
    }
  },
  "error_handling": {
    "retry_network": true,
    "max_retries": 3
  }
}
